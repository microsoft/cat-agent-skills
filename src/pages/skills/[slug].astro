---
import Layout from "../../layouts/Layout.astro";
import SkillCover from "../../components/SkillCover.astro";
import { getCollection, render } from "astro:content";
import { formatDate, PLATFORM_COLORS } from "../../lib/skills";
import { withBase } from "../../lib/url";
import { getRating } from "../../lib/ratings";
import { ANALYTICS_ENABLED } from "../../lib/analytics-config";
import {
  RATINGS_ENABLED,
  GISCUS_REPO,
  GISCUS_REPO_ID,
  GISCUS_CATEGORY,
  GISCUS_CATEGORY_ID,
} from "../../lib/ratings-config";

export async function getStaticPaths() {
  const skills = await getCollection("skills");
  return skills.map((skill) => ({
    params: { slug: skill.id },
    props: { skill },
  }));
}

const { skill } = Astro.props;
const d = skill.data;
const isPlugin = d.type === "plugin";
const noun = isPlugin ? "plugin" : "skill";
const { Content } = await render(skill);

const updated = formatDate(d.updatedAt ?? d.createdAt);
const created = formatDate(d.createdAt);
const rating = getRating(skill.id);
const isSample = d.tags.includes("sample");

const meta: Array<[string, string, string?]> = [];
if (d.author) meta.push(["Author", d.author, d.authorUrl]);
if (d.version) meta.push(["Version", d.version]);
if (created) meta.push(["Added", created]);
if (updated && updated !== created) meta.push(["Updated", updated]);
---

<Layout title={d.name} description={d.description}>
  <div class="mx-auto max-w-5xl px-4 py-6 sm:px-6 sm:py-8">
    <a
      href={withBase("/")}
      class="inline-flex items-center gap-1.5 text-sm text-slate-400 hover:text-white transition-colors"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        class="h-4 w-4"
      >
        <path d="m15 18-6-6 6-6" stroke-linecap="round" stroke-linejoin="round"
        ></path>
      </svg>
      Back to gallery
    </a>

    <div class="mt-5 overflow-hidden rounded-2xl border border-white/5">
      <SkillCover
        slug={skill.id}
        name={d.name}
        platforms={d.platforms}
        tags={d.tags}
        coverColor={d.coverColor}
        hasBundle={Boolean(d.bundle)}
        type={d.type}
        variant="hero"
      />
    </div>

    {
      isSample && (
        <div class="mt-5 flex items-start gap-3 rounded-xl border border-amber-400/40 bg-amber-400/10 p-4">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="mt-0.5 h-5 w-5 shrink-0 text-amber-400"
          >
            <path d="M12 2 3 7v10l9 5 9-5V7l-9-5zm0 2.3L18 8v.02l-6 3.33-6-3.33V8l6-3.7zM5 9.7l6 3.33v6.64l-6-3.33V9.7zm14 0v6.64l-6 3.33v-6.64l6-3.33z" />
          </svg>
          <p class="text-sm text-amber-100/90">
            <span class="font-semibold text-amber-200">Sample {noun}.</span> This
            is placeholder / demo content included to show how the gallery works —
            not a real, production-ready submission.
          </p>
        </div>
      )
    }

    <div class="mt-8 grid gap-8 lg:grid-cols-[1fr_18rem]">
      <!-- Main content -->
      <div>
        <p class="text-lg text-slate-300">{d.description}</p>

        <div class="mt-3 flex items-center gap-2">
          <a
            href="#rate"
            class="inline-flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-sm font-medium text-slate-200 hover:border-brand-500/50 hover:text-white transition-colors"
            title={`Rate this ${noun}`}
          >
            <span aria-hidden="true">👍</span>
            <span>{rating}</span>
            <span class="text-slate-400">{rating === 1 ? "rating" : "ratings"}</span>
          </a>
        </div>

        {
          d.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {d.tags.map((tag) => (
                <a
                  href={withBase(`/tags/${encodeURIComponent(tag)}`)}
                  class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-sm text-slate-300 hover:border-brand-500/50 hover:text-white transition-colors"
                >
                  {tag}
                </a>
              ))}
            </div>
          )
        }

        <hr class="my-7 border-white/5" />

        {
          d.agentDescription && (
            <div class="mb-6">
              <h2 class="mb-2 text-sm font-semibold uppercase tracking-wider text-brand-300">
                Description
              </h2>
              <p class="text-slate-300">{d.agentDescription}</p>
            </div>
          )
        }

        <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-brand-300">
          Instructions
        </h2>
        <article
          class="prose prose-invert max-w-none prose-headings:text-white prose-a:text-brand-300 prose-strong:text-white prose-code:text-brand-200 prose-code:before:content-[''] prose-code:after:content-[''] prose-table:text-slate-300 prose-th:text-white"
        >
          <Content />
        </article>
      </div>

      <!-- Sidebar -->
      <aside class="lg:sticky lg:top-20 lg:self-start">
        <div class="rounded-2xl border border-white/5 bg-ink-900 p-5">
          <h3 class="text-xs font-semibold uppercase tracking-wider text-slate-500">
            Works with
          </h3>
          <div class="mt-2 flex flex-wrap gap-2">
            {
              d.platforms.map((platform) => (
                <span class="flex items-center gap-1.5 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-sm font-medium text-slate-200">
                  <span
                    class="h-2 w-2 rounded-full"
                    style={`background:${PLATFORM_COLORS[platform]}`}
                  />
                  {platform}
                </span>
              ))
            }
          </div>

          <hr class="my-5 border-white/5" />

          <h3 class="text-sm font-semibold text-white">
            {isPlugin ? "Add this plugin" : "Add this skill"}
          </h3>
          <p class="mt-1 text-xs text-slate-400">
            {
              isPlugin
                ? "Download the plugin package and install it in Microsoft 365 Copilot Cowork."
                : `Download the ${
                    d.bundle ? "bundle" : "instructions"
                  } and add ${d.bundle ? "it" : "them"} to ${
                    d.platforms.length === 1 ? d.platforms[0] : "your platform"
                  }.`
            }
          </p>

          <div class="mt-4 flex flex-col gap-2">
            {
              isPlugin ? (
                d.bundle && (
                  <a
                    href={withBase(`/${d.bundle}`)}
                    download
                    data-clarity-event="skill_download"
                    data-clarity-skill={skill.id}
                    data-clarity-download-type="plugin"
                    class="flex items-center justify-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-500 transition-colors"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="h-4 w-4"
                    >
                      <path d="M3 7a2 2 0 0 1 2-2h4l2 2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z" />
                    </svg>
                    Download plugin package (.zip)
                  </a>
                )
              ) : (
                <>
                  {d.bundle ? (
                    <a
                      href={withBase(`/${d.bundle}`)}
                      download
                      data-clarity-event="skill_download"
                      data-clarity-skill={skill.id}
                      data-clarity-download-type="bundle"
                      class="flex items-center justify-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-500 transition-colors"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="h-4 w-4"
                      >
                        <path d="M3 7a2 2 0 0 1 2-2h4l2 2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z" />
                      </svg>
                      Download bundle (.zip)
                    </a>
                  ) : (
                    <a
                      href={withBase(`/skills/${skill.id}.md`)}
                      download="SKILL.md"
                      data-clarity-event="skill_download"
                      data-clarity-skill={skill.id}
                      data-clarity-download-type="markdown"
                      class="flex items-center justify-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-brand-500 transition-colors"
                    >
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        class="h-4 w-4"
                      >
                        <path
                          d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                      Download .md
                    </a>
                  )}
                </>
              )
            }
          </div>

          {
            meta.length > 0 && (
              <dl class="mt-5 space-y-2 border-t border-white/5 pt-4 text-sm">
                {meta.map(([k, v, href]) => (
                  <div class="flex justify-between gap-3">
                    <dt class="text-slate-400">{k}</dt>
                    <dd class="text-right font-medium text-slate-200">
                      {href ? (
                        <a
                          href={href}
                          target="_blank"
                          rel="noopener"
                          class="text-brand-300 underline hover:text-brand-200 transition-colors"
                        >
                          {v}
                        </a>
                      ) : (
                        v
                      )}
                    </dd>
                  </div>
                ))}
              </dl>
            )
          }

          <p class="mt-5 border-t border-white/5 pt-4 text-xs text-slate-500">
            This {noun} is an example implementation provided as-is. See{" "}
            <a
              href="https://github.com/microsoft/cat-agent-skills/blob/main/SUPPORT.md"
              target="_blank"
              rel="noopener"
              class="underline hover:text-slate-300 transition-colors"
              >Support</a
            >{" "}for how to get help.
          </p>
        </div>
      </aside>
    </div>

    <section id="rate" class="mt-10 scroll-mt-24 border-t border-white/5 pt-8">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-brand-300">
        Rate &amp; discuss this {noun}
      </h2>
      {
        RATINGS_ENABLED ? (
          <>
            <p class="mt-2 text-sm text-slate-400">
              Give this {noun} a 👍 with your GitHub account. Ratings power the
              gallery's "Top rated" sort (refreshed on each deploy).
            </p>
            <div class="mt-5">
              <script
                is:inline
                src="https://giscus.app/client.js"
                data-repo={GISCUS_REPO}
                data-repo-id={GISCUS_REPO_ID}
                data-category={GISCUS_CATEGORY}
                data-category-id={GISCUS_CATEGORY_ID}
                data-mapping="specific"
                data-term={skill.id}
                data-strict="1"
                data-reactions-enabled="1"
                data-emit-metadata="0"
                data-input-position="bottom"
                data-theme="dark"
                data-lang="en"
                crossorigin="anonymous"
                async
              />
            </div>
          </>
        ) : (
          <p class="mt-2 text-sm text-slate-400">
            Ratings open in a{" "}
            <a
              href={`https://github.com/${GISCUS_REPO}/discussions`}
              target="_blank"
              rel="noopener"
              class="text-brand-300 underline hover:text-brand-200 transition-colors"
            >
              GitHub Discussion
            </a>{" "}
            for each skill. This gallery isn't wired to a Discussions category
            yet, so voting is temporarily unavailable.
          </p>
        )
      }
    </section>
  </div>
  {
    ANALYTICS_ENABLED && (
      <script
        is:inline
        set:html={`(function(){function fire(){if(typeof window.clarity!=="function"){return setTimeout(fire,300);}window.clarity("set","skill",${JSON.stringify(
          skill.id
        )});window.clarity("set","skillType",${JSON.stringify(
          d.type
        )});window.clarity("event","skill_view");}fire();})();`}
      />
    )
  }
</Layout>
