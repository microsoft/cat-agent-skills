---
import Layout from "../layouts/Layout.astro";
import { withBase } from "../lib/url";
---

<Layout title="Page not found">
  <div
    class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center sm:px-6"
  >
    <p class="text-7xl font-black text-accent">404</p>
    <h1 class="mt-4 text-2xl font-bold text-fg">This page wandered off</h1>
    <p class="mt-2 text-muted">
      The skill or page you’re looking for doesn’t exist (or moved).
    </p>
    <a
      href={withBase("/")}
      class="mt-6 rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-accent-fg hover:opacity-90 transition-opacity"
      >Back to the gallery</a
    >
  </div>
</Layout>
