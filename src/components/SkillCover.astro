---
import { coverGradient, initials, PLATFORM_COLORS, type Platform, type SkillType } from "../lib/skills";

interface Props {
  slug: string;
  name: string;
  platforms?: Platform[];
  type?: SkillType;
  tags?: string[];
  coverColor?: string;
  hasBundle?: boolean;
  /** "card" for grid thumbnails, "hero" for the detail header. */
  variant?: "card" | "hero";
  class?: string;
}

const {
  slug,
  name,
  platforms = [],
  type = "skill",
  tags = [],
  coverColor,
  hasBundle = false,
  variant = "card",
  class: className = "",
} = Astro.props;

const gradient = coverGradient(slug, coverColor);
const mark = initials(name);
const isHero = variant === "hero";
const isSample = tags.includes("sample");
const shownTags = tags.filter((t) => t !== "sample");
const shownPlatforms = isHero ? platforms : platforms.slice(0, 2);
const extraPlatforms = platforms.length - shownPlatforms.length;
---

<div
  class:list={[
    "relative overflow-hidden",
    isHero ? "h-56 sm:h-64" : "aspect-[16/10]",
    isSample && "ring-2 ring-inset ring-amber-400/70",
    className,
  ]}
  style={`background-image:${gradient}`}
>
  <!-- decorative texture -->
  <div
    class="absolute inset-0 opacity-25"
    style="background-image: radial-gradient(circle at 20% 20%, rgba(255,255,255,.5) 0, transparent 40%), radial-gradient(circle at 80% 0%, rgba(255,255,255,.35) 0, transparent 35%);"
  >
  </div>
  <div
    class="absolute -right-6 -top-8 select-none font-black text-white/15 leading-none"
    class:list={[isHero ? "text-[12rem]" : "text-[7rem]"]}
  >
    {mark}
  </div>

  <div
    class="relative flex h-full flex-col justify-between p-4"
    class:list={[isHero && "p-6 sm:p-8"]}
  >
    <div class="flex items-center justify-between gap-2">
      <div class="flex flex-wrap items-center gap-1.5">
        {
          isSample && (
            <span
              class="flex items-center gap-1 rounded-md bg-amber-400 px-2 py-1 text-[10px] font-bold uppercase tracking-wide text-neutral-900 shadow-sm"
              title="A sample / demo skill — placeholder content, not a real submission"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="h-3 w-3"
              >
                <path d="M12 2 3 7v10l9 5 9-5V7l-9-5zm0 2.3L18 8v.02l-6 3.33-6-3.33V8l6-3.7zM5 9.7l6 3.33v6.64l-6-3.33V9.7zm14 0v6.64l-6 3.33v-6.64l6-3.33z" />
              </svg>
              Sample
            </span>
          )
        }
        {
          type === "plugin" && (
            <span
              class="flex items-center gap-1 rounded-md bg-accent px-2 py-1 text-[10px] font-bold uppercase tracking-wide text-accent-fg backdrop-blur-sm"
              title="A Cowork plugin (M365 app package)"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                class="h-3 w-3"
              >
                <path d="M10 3v4a1 1 0 0 1-1 1H5m14 0h-4a1 1 0 0 1-1-1V3m0 18v-4a1 1 0 0 1 1-1h4M5 16h4a1 1 0 0 1 1 1v4M4 8h16v8H4z" />
              </svg>
              Plugin
            </span>
          )
        }
        {
          type === "automation" && (
            <span
              class="flex items-center gap-1 rounded-md bg-accent px-2 py-1 text-[10px] font-bold uppercase tracking-wide text-accent-fg backdrop-blur-sm"
              title="A Scout automation (scheduled .json)"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-3 w-3"
              >
                <circle cx="12" cy="12" r="9" />
                <path d="M12 7v5l3 2" />
              </svg>
              Automation
            </span>
          )
        }
        {
          shownPlatforms.map((platform) => (
            <span
              class="flex items-center gap-1.5 rounded-md bg-black/30 px-2 py-1 text-[10px] font-semibold text-white backdrop-blur-sm"
            >
              <span
                class="h-1.5 w-1.5 rounded-full"
                style={`background:${PLATFORM_COLORS[platform]}`}
              />
              {platform}
            </span>
          ))
        }
        {
          extraPlatforms > 0 && (
            <span class="rounded-md bg-black/30 px-2 py-1 text-[10px] font-semibold text-white backdrop-blur-sm">
              +{extraPlatforms}
            </span>
          )
        }
      </div>
      {
        hasBundle && (
          <span
            class="flex items-center gap-1 rounded-md bg-black/25 px-2 py-1 text-[10px] font-semibold text-white/90 backdrop-blur-sm"
            title={
              type === "automation"
                ? "Includes a downloadable automation file"
                : "Includes a downloadable script bundle"
            }
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-3 w-3"
            >
              <path d="M3 7a2 2 0 0 1 2-2h4l2 2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z" />
            </svg>
            {type === "automation" ? ".json" : ".zip"}
          </span>
        )
      }
    </div>

    <div>
      <h3
        class="font-bold leading-tight text-white drop-shadow-sm"
        class:list={[isHero ? "text-3xl sm:text-4xl" : "text-lg line-clamp-2"]}
      >
        {name}
      </h3>
      {
        shownTags.length > 0 && (
          <div class="mt-2 flex flex-wrap gap-1.5">
            {shownTags.slice(0, isHero ? 8 : 3).map((t) => (
              <span class="rounded-full bg-white/20 px-2 py-0.5 text-[10px] font-medium text-white backdrop-blur-sm">
                {t}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </div>
</div>
