---
import { withBase } from "../lib/url";
import { coverGradient, initials, PLATFORM_COLORS } from "../lib/skills";
import type { Platform, SkillType } from "../lib/skills";

interface Props {
  slug: string;
  name: string;
  description: string;
  platforms?: Platform[];
  type?: SkillType;
  tags?: string[];
  author?: string;
  coverColor?: string;
  hasBundle?: boolean;
  rating?: number;
}

const {
  slug,
  name,
  description,
  platforms = [],
  type = "skill",
  tags = [],
  author,
  coverColor,
  hasBundle = false,
  rating = 0,
} = Astro.props;

const gradient = coverGradient(slug, coverColor);
const mark = initials(name);
const isSample = tags.includes("sample");
const isPlugin = type === "plugin";
const isAutomation = type === "automation";
const shownTags = tags.filter((t) => t !== "sample").slice(0, 3);
---

<a
  href={withBase(`/skills/${slug}`)}
  class="group flex h-full flex-col rounded-xl border border-border bg-surface p-4 transition-all duration-200 hover:-translate-y-0.5 hover:border-accent/40 hover:shadow-md"
>
  <!-- Header: monogram + name + platforms -->
  <div class="flex items-start gap-3">
    <span
      class="grid h-11 w-11 shrink-0 place-items-center rounded-lg text-sm font-bold text-white shadow-sm"
      style={`background-image:${gradient}`}
      aria-hidden="true"
    >
      {mark}
    </span>
    <div class="min-w-0 flex-1">
      <div class="flex items-start gap-1.5">
        <h3
          class="line-clamp-2 min-w-0 font-semibold text-fg transition-colors group-hover:text-accent-text"
          title={name}
        >
          {name}
        </h3>
        {
          isPlugin && (
            <span
              class="shrink-0 rounded bg-accent-soft px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-accent-text"
              title="A Cowork plugin (M365 app package)"
            >
              Plugin
            </span>
          )
        }
        {
          isAutomation && (
            <span
              class="shrink-0 rounded bg-accent-soft px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-accent-text"
              title="A Scout automation (scheduled .json)"
            >
              Automation
            </span>
          )
        }
        {
          isSample && (
            <span
              class="shrink-0 rounded bg-amber-400/20 px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-amber-600 dark:text-amber-400"
              title="A sample / demo skill — placeholder content"
            >
              Sample
            </span>
          )
        }
      </div>
      {
        platforms.length > 0 && (
          <div class="mt-1 flex flex-wrap items-center gap-x-2.5 gap-y-1">
            {platforms.map((platform) => (
              <span class="flex items-center gap-1 text-xs text-muted">
                <span
                  class="h-1.5 w-1.5 rounded-full"
                  style={`background:${PLATFORM_COLORS[platform]}`}
                />
                {platform}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </div>

  <!-- Description — the tile's focus -->
  <p class="mt-3 flex-1 text-sm leading-relaxed text-muted line-clamp-3">
    {description}
  </p>

  <!-- Footer: tags + rating/download hints -->
  <div
    class="mt-4 flex items-center justify-between gap-2 border-t border-border pt-3"
  >
    <div class="flex min-w-0 flex-wrap items-center gap-1.5">
      {
        shownTags.map((t) => (
          <span class="rounded-full bg-surface-2 px-2 py-0.5 text-[11px] font-medium text-muted">
            {t}
          </span>
        ))
      }
      {
        shownTags.length === 0 && (
          <span class="truncate text-xs text-subtle">
            {author ? `by ${author}` : isPlugin ? "Cowork plugin" : isAutomation ? "Scout automation" : "Community skill"}
          </span>
        )
      }
    </div>
    <span class="flex shrink-0 items-center gap-2.5 text-xs text-subtle">
      {
        hasBundle && (
          <span class="flex items-center gap-1" title={isAutomation ? "Includes a downloadable automation file" : "Includes a downloadable bundle"}>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-3.5 w-3.5"
            >
              <path d="M3 7a2 2 0 0 1 2-2h4l2 2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z" />
            </svg>
            {isAutomation ? ".json" : ".zip"}
          </span>
        )
      }
      {
        rating > 0 && (
          <span
            class="flex items-center gap-1"
            title={`${rating} ${rating === 1 ? "rating" : "ratings"}`}
          >
            <span aria-hidden="true">👍</span>
            {rating}
          </span>
        )
      }
    </span>
  </div>
</a>
