---
import SkillCover from "./SkillCover.astro";
import { withBase } from "../lib/url";
import type { Platform, SkillType } from "../lib/skills";

interface Props {
  slug: string;
  name: string;
  description: string;
  platforms?: Platform[];
  type?: SkillType;
  tags?: string[];
  author?: string;
  coverColor?: string;
  hasBundle?: boolean;
  rating?: number;
}

const {
  slug,
  name,
  description,
  platforms = [],
  type = "skill",
  tags = [],
  author,
  coverColor,
  hasBundle = false,
  rating = 0,
} = Astro.props;
---

<a
  href={withBase(`/skills/${slug}`)}
  class="group flex flex-col overflow-hidden rounded-2xl border border-white/5 bg-ink-900 shadow-lg shadow-black/30 transition-all duration-200 hover:-translate-y-1 hover:border-brand-500/40 hover:shadow-brand-700/20"
>
  <div class="overflow-hidden">
    <div class="transition-transform duration-300 group-hover:scale-[1.04]">
      <SkillCover
        slug={slug}
        name={name}
        platforms={platforms}
        type={type}
        tags={tags}
        coverColor={coverColor}
        hasBundle={hasBundle}
      />
    </div>
  </div>
  <div class="flex flex-1 flex-col p-4">
    <p class="line-clamp-2 text-sm text-slate-300">{description}</p>
    <div
      class="mt-3 flex items-center justify-between border-t border-white/5 pt-3 text-xs text-slate-400"
    >
      <span class="truncate">{author ? `by ${author}` : type === "plugin" ? "Cowork plugin" : "Community skill"}</span
      >
      <span class="flex shrink-0 items-center gap-3">
        {
          rating > 0 && (
            <span
              class="flex items-center gap-1 text-slate-400"
              title={`${rating} ${rating === 1 ? "rating" : "ratings"}`}
            >
              <span aria-hidden="true">👍</span>
              {rating}
            </span>
          )
        }
        <span
          class="font-medium text-brand-300 opacity-0 transition-opacity group-hover:opacity-100"
          >View →</span
        >
      </span>
    </div>
  </div>
</a>
